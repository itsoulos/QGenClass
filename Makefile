		GE/doublestack.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o integerhill.o GE/integerhill.cpp

population.o: GE/population.cc GE/population.h \
		GE/program.h \
		GE/symbol.h \
		GE/rule.h \
		GE/doublestack.h \
		CORE/problem.h \
		GE/integeranneal.h \
		GE/integerhill.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o population.o GE/population.cc

program.o: GE/program.cc GE/program.h \
		GE/symbol.h \
		GE/rule.h \
		GE/doublestack.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o program.o GE/program.cc

rule.o: GE/rule.cc GE/rule.h \
		GE/symbol.h \
