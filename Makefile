####### Compile

dataset.o: CORE/dataset.cpp CORE/dataset.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o dataset.o CORE/dataset.cpp

parameter.o: CORE/parameter.cpp CORE/parameter.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o parameter.o CORE/parameter.cpp

parameterlist.o: CORE/parameterlist.cpp CORE/parameterlist.h \
		CORE/parameter.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o parameterlist.o CORE/parameterlist.cpp

problem.o: CORE/problem.cpp CORE/problem.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o problem.o CORE/problem.cpp

classprogram.o: GE/classprogram.cc GE/classprogram.h \
		GE/program.h \
		GE/symbol.h \
		GE/rule.h \
		GE/doublestack.h \
		GE/cprogram.h \
		GE/fparser.hh \
		CORE/dataset.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o classprogram.o GE/classprogram.cc

cprogram.o: GE/cprogram.cc GE/cprogram.h \
		GE/symbol.h \
		GE/rule.h \
		GE/doublestack.h \
		GE/fparser.hh
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o cprogram.o GE/cprogram.cc

doublestack.o: GE/doublestack.cc GE/doublestack.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o doublestack.o GE/doublestack.cc

fparser.o: GE/fparser.cc GE/fparser.hh \
		GE/fpconfig.hh \
		GE/fptypes.hh
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o fparser.o GE/fparser.cc

fpoptimizer.o: GE/fpoptimizer.cc GE/fpconfig.hh \
		GE/fparser.hh \
		GE/fptypes.hh
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o fpoptimizer.o GE/fpoptimizer.cc

integeranneal.o: GE/integeranneal.cpp GE/integeranneal.h \
