		GE/program.h \
		GE/symbol.h \
		GE/rule.h \
		GE/doublestack.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o integeranneal.o GE/integeranneal.cpp

integerhill.o: GE/integerhill.cpp GE/integerhill.h \
		CORE/problem.h \
